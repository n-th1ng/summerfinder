# --- Database -----------------------------------------------------------------
# Supabase Postgres connection string. Get this from:
#   Supabase project -> Project Settings -> Database -> Connection string (URI)
# Replace [YOUR-PASSWORD] with the database password you set when creating the
# project. Example:
#   DATABASE_URL="postgresql://postgres:YourPassword@db.abcdefg.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# --- Supabase (optional) ------------------------------------------------------
# Only needed if you use the @supabase/supabase-js client. For now SummerFinder
# talks to Postgres directly through Prisma, so these are optional.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Admin --------------------------------------------------------------------
# Comma-separated list of admin codes that can unlock /admin dashboard.
ADMIN_PASSCODE="letmein"